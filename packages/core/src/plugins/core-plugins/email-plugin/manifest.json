{
  "id": "email",
  "name": "Email",
  "version": "1.0.0",
  "description": "Send transactional emails via Cloudflare Email Service. Subscribes to auth lifecycle events (welcome, password reset, password changed) and runs a 5-minute reconciliation cron against the CF GraphQL Activity Log.",
  "author": "SonicJS Team",
  "homepage": "https://github.com/sonicjs/sonicjs-ai",
  "repository": "https://github.com/sonicjs/sonicjs-ai",
  "license": "MIT",
  "category": "utilities",
  "tags": [
    "email",
    "cloudflare-email",
    "transactional",
    "notifications",
    "templates"
  ],
  "dependencies": [],
  "capabilities": [
    "email:send",
    "hooks.cron:register",
    "hooks.auth:register"
  ],
  "crons": [
    {
      "schedule": "*/5 * * * *",
      "hookFamily": "email-reconciliation"
    }
  ],
  "configSchema": {
    "fromEmail": {
      "type": "string",
      "label": "From Email",
      "format": "email",
      "required": true,
      "placeholder": "noreply@yourdomain.com",
      "description": "Must be a verified sender address in your Cloudflare account"
    },
    "fromName": {
      "type": "string",
      "label": "From Name",
      "required": true,
      "placeholder": "Your App Name"
    },
    "replyTo": {
      "type": "string",
      "label": "Reply-To Email",
      "format": "email",
      "required": false,
      "placeholder": "support@yourdomain.com"
    },
    "logoUrl": {
      "type": "string",
      "label": "Logo URL",
      "format": "url",
      "required": false,
      "placeholder": "https://yourdomain.com/logo.png",
      "description": "Logo to display in email templates"
    },
    "cfAccountId": {
      "type": "string",
      "label": "CF Account ID",
      "required": false,
      "placeholder": "f61c658f...",
      "description": "Reconciliation credential (delivery-sync cron). Found in the Cloudflare dashboard right sidebar"
    },
    "cfEmailApiToken": {
      "type": "string",
      "label": "CF Email API Token",
      "sensitive": true,
      "required": false,
      "placeholder": "••••••••",
      "description": "Reconciliation credential. API token with Email Routing read permission"
    }
  },
  "permissions": {
    "email:manage": "Manage email settings",
    "email:send": "Send emails",
    "email:view-logs": "View email logs"
  },
  "adminMenu": {
    "label": "Email",
    "icon": "envelope",
    "path": "/admin/plugins/email/settings",
    "order": 80
  },
  "iconEmoji": "📧",
  "is_core": true,
  "defaultSettings": {
    "fromEmail": "",
    "fromName": "",
    "replyTo": "",
    "logoUrl": "",
    "cfAccountId": "",
    "cfEmailApiToken": ""
  }
}
